generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversa {
  id              String     @id
  nome            String
  telefone        String
  profile_pic_url String?
  status_bot      Boolean    @default(true)
  ultima_mensagem String?
  assumido_por    String?
  valor_conversa  Float      @default(0) // Novo: Valor financeiro do lead
  
  // Phase 5 Fills
  status_kanban   String     @default("Novos") // Novos, Em Orçamento, Aguardando Arte/Aprovação, Em Produção, Finalizado
  tags            String?    // Ex: "Atacado,Urgente"
  etiquetas       Etiqueta[] // Campo de relação obrigatório
  
  // Master Phase
  unreadCount     Int        @default(0)
  lembrete_horas  Int?       // Quantas horas para disparar o follow-up se não houver resposta
  
  // Soft Delete
  deleted_at      DateTime?
  deleted_by      String?

  // Follow-up Automático por Funil
  funil_tipo           String?   // 'nao_respondeu' | 'orcamento_sumiu' | 'recorrente'
  funil_step           Int?      // qual mensagem da sequência (1, 2, 3)
  funil_proximo        DateTime? // quando disparar a próxima mensagem
  funil_ultimo_disparo DateTime? // quando foi o último envio
  cliente_comprou_em   DateTime? // data da entrega (para funil recorrente)

  criado_em       DateTime   @default(now())
  atualizado_em   DateTime   @updatedAt
  mensagens       Mensagem[]
  followups       FollowUp[]
}


model Mensagem {
  id         String   @id @default(uuid())
  conversaId String
  conversa   Conversa @relation(fields: [conversaId], references: [id])
  texto      String
  
  // Phase 5 Fills
  mediaUrl   String?
  mediaType  String?  // 'image', 'audio', 'video', 'document'
  
  // Master Phase
  agendado_para DateTime?
  status_envio  String?   // "Pendente", "Enviado", "Falha" (Usado só se agendado)
  
  origem     String   // "cliente" ou "bot" ou "loja"
  criado_em  DateTime @default(now())
}

model RespostaRapida {
  id         String   @id @default(uuid())
  atalho     String   // ex: "/pix"
  texto      String   // ex: "Nossa chave pix é X"
  midiaUrl   String?  // novo: url para anexo de media
  midiaTipo  String?  // novo: image/audio/etc
  criado_em  DateTime @default(now())
}

model Etiqueta {
  id              Int      @id @default(autoincrement())
  nome            String   @unique
  cor             String
  followup_texto  String?  // nova: mensagem pré-pronta
  followup_horas  Int?    // nova: tempo em horas para envio
  conversas       Conversa[]
  criado_em       DateTime @default(now())
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  senha     String
  criado_em DateTime @default(now())
}

model FollowUp {
  id            String   @id @default(uuid())
  conversaId    String
  conversa      Conversa @relation(fields: [conversaId], references: [id])
  texto         String
  agendado_para DateTime
  status        String   @default("pendente") // pendente, enviado, cancelado
  tentativas    Int      @default(0)
  criado_em     DateTime @default(now())
  enviado_em    DateTime?
}

model PipelineColumn {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  cor       String   @default("hsl(210,80%,55%)")
  ordem     Int      @default(0)
  criado_em DateTime @default(now())
}
